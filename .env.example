# IBM watsonx.ai Configuration
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_watsonx_api_key_here

# Get your project ID from your watsonx.ai project settings
WATSONX_PROJECT_ID=your_project_id_here

# Target Repository Configuration (Optional)
# Path to the legacy codebase you want to analyze
# Leave empty to be prompted at runtime
TARGET_REPO_PATH=

# MCP Server Configuration (Optional)
# Port for MCP server communication
MCP_SERVER_PORT=3000

# Logging Configuration (Optional)
# Set to DEBUG, INFO, WARNING, or ERROR
LOG_LEVEL=INFO

# Output Configuration (Optional)
# Directory where generated documentation will be saved
OUTPUT_DIR=docs/onboarding/generated

# Advanced watsonx.ai Settings (Optional)
# Override default model parameters if needed
# WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
# WATSONX_MAX_TOKENS=1000
# WATSONX_TEMPERATURE=0.7
# WATSONX_TOP_P=0.9