{
  "name": "devramp-mcp-servers",
  "version": "1.0.0",
  "description": "Model Context Protocol servers for Legacy Codebase Onboarding Accelerator",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:code-analyzer && npm run build:git-analyzer && npm run build:documentation-generator",
    "build:code-analyzer": "tsc --project code-analyzer/tsconfig.json",
    "build:git-analyzer": "tsc --project git-analyzer/tsconfig.json",
    "build:documentation-generator": "tsc --project documentation-generator/tsconfig.json",
    "start:code-analyzer": "node code-analyzer/build/server.js",
    "start:git-analyzer": "node git-analyzer/build/server.js",
    "start:documentation-generator": "node documentation-generator/build/server.js",
    "watch": "tsc --watch",
    "clean": "rimraf code-analyzer/build git-analyzer/build documentation-generator/build",
    "prebuild": "npm run clean",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "watsonx",
    "code-analysis",
    "legacy-code",
    "onboarding"
  ],
  "author": "DevRamp Team",
  "license": "MIT",
  "dependencies": {
    "@ibm-cloud/watsonx-ai": "^1.7.12",
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
